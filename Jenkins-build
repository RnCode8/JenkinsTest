pipeline {
    agent any

    stage('Check Java') {
        steps {
            sh 'java -version'
            sh 'mvn -v'
        }
    }

    stages {
        stage('Compile') {
            steps {
                echo 'Compiling project...'
                sh 'mvn clean compile'
            }
        }

        stage('Trigger Test Job') {
            steps {
                echo 'Triggering test job...'
                build job: 'Pipeline-Test'
            }
        }
    }
}